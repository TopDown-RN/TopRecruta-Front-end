# Matches credentials in docker-compose.yml (local dev)
# Host 5434 (see docker-compose) — inside Docker the API still uses postgres:5432
DATABASE_URL="postgresql://toprecruta:toprecruta@localhost:5434/toprecruta?schema=public"

PORT=3000
CORS_ORIGIN="http://localhost:4200"

JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_DAYS=7
AUTH_USERNAME="admin"
AUTH_PASSWORD="123456"
